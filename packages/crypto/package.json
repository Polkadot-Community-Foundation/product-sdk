{
  "name": "@parity/product-sdk-crypto",
  "version": "0.0.1",
  "description": "Unified cryptographic utilities for Polkadot Product SDK",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./encryption": {
      "import": "./dist/encryption.js",
      "types": "./dist/encryption.d.ts"
    },
    "./hashing": {
      "import": "./dist/hashing.js",
      "types": "./dist/hashing.d.ts"
    },
    "./kdf": {
      "import": "./dist/kdf.js",
      "types": "./dist/kdf.d.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "eslint src/",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@noble/ciphers": "^1.2.1",
    "@noble/hashes": "^1.7.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "keywords": [
    "polkadot",
    "crypto",
    "encryption",
    "aes-gcm",
    "x25519",
    "blake2b",
    "sha256"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/parity/product-sdk"
  }
}
