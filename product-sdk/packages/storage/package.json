        "test": "vitest",
        "clean": "rm -rf dist"
    },
    "dependencies": {
        "@parity/product-sdk-logger": "workspace:*",
        "@parity/product-sdk-host": "workspace:*"
    },
    "devDependencies": {
        "typescript": "^5.7.0",
        "vitest": "^3.0.0"
    },
    "license": "Apache-2.0"
}
