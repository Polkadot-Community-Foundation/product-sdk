{
    "name": "@parity/product-sdk-storage",
    "version": "0.1.0",
    "description": "Key-value storage abstraction with automatic host/browser backend detection",
    "type": "module",
    "sideEffects": false,
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts"
        }
