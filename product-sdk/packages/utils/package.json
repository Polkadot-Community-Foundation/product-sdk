{
    "name": "@parity/product-sdk-utils",
    "description": "Encoding utilities and token formatting for the @parity/product-sdk ecosystem",
    "version": "0.1.0",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "source": "./src/index.ts",
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "files": ["dist"],
    "sideEffects": false,
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "build": "tsup",
        "clean": "rm -rf dist",
        "test": "vitest run",
        "test:watch": "vitest"
    },
    "dependencies": {
        "@noble/hashes": "^1.7.1",
        "@parity/product-sdk-logger": "workspace:*"
    },
    "devDependencies": {
        "tsup": "^8.4.0",
        "typescript": "^5.8.3",
        "vitest": "^3.1.2"
    }
}
