{
    "name": "@parity/product-sdk-signer",
    "version": "0.4.0",
    "description": "Signer manager for Polkadot — Host API and dev accounts",
    "type": "module",
    "sideEffects": false,
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts"
        }
    },
    "files": ["dist", "src"],
    "scripts": {
        "build": "tsup",
        "test": "vitest",
        "clean": "rm -rf dist"
    },
    "dependencies": {
        "@parity/product-sdk-address": "workspace:*",
        "@parity/product-sdk-host": "workspace:*",
        "@parity/product-sdk-keys": "workspace:*",
        "@parity/product-sdk-logger": "workspace:*",
        "polkadot-api": "catalog:"
    },
    "optionalDependencies": {
        "@novasamatech/host-api-wrapper": "catalog:",
        "@novasamatech/host-api": "catalog:"
    },
    "devDependencies": {
        "tsup": "catalog:",
        "typescript": "catalog:",
        "vitest": "catalog:"
    },
    "license": "Apache-2.0"
}
