{
    "name": "@parity/product-sdk-terminal",
    "description": "QR code login and signing for CLI/terminal apps via Polkadot mobile wallet pairing",
    "version": "0.3.2",
    "type": "module",
    "sideEffects": false,
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        },
        "./testing": {
            "types": "./dist/testing.d.ts",
            "import": "./dist/testing.js"
        },
        "./host": {
            "types": "./dist/host.d.ts",
            "import": "./dist/host.js"
        }
    },
    "files": ["dist"],
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "build": "tsup",
        "clean": "rm -rf dist",
        "pretest": "tsup",
        "test": "vitest run"
    },
    "dependencies": {
        "@noble/ciphers": "^2.1.0",
        "@noble/curves": "^2.0.1",
        "@noble/hashes": "^2.2.0",
        "@novasamatech/host-papp": "^0.8.6",
        "@novasamatech/statement-store": "^0.8.6",
        "@novasamatech/storage-adapter": "^0.8.6",
        "@parity/product-sdk-logger": "workspace:*",
        "@polkadot-api/substrate-bindings": "^0.20.2",
        "@polkadot-api/utils": "^0.4.0",
        "@polkadot-api/ws-provider": "^0.9.0",
        "@polkadot-labs/hdkd-helpers": "catalog:",
        "nanoid": "^5.1.7",
        "neverthrow": "^8.2.0",
        "polkadot-api": "catalog:",
        "qrcode": "^1.5.4",
        "scale-ts": "^1.6.1"
    },
    "devDependencies": {
        "@types/qrcode": "^1.5.5",
        "tsup": "catalog:",
        "typescript": "catalog:",
        "vitest": "catalog:"
    },
    "license": "Apache-2.0"
}
