{
    "name": "@parity/product-sdk-descriptors",
    "version": "0.6.2",
    "description": "PAPI-generated chain descriptors for Polkadot ecosystem",
    "license": "Apache-2.0",
    "type": "module",
    "sideEffects": false,
    "exports": {
        "./kusama-asset-hub": {
            "types": "./chains/kusama-asset-hub/generated/dist/index.d.ts",
            "import": "./chains/kusama-asset-hub/generated/dist/index.js"
        },
        "./paseo-asset-hub": {
            "types": "./chains/paseo-asset-hub/generated/dist/index.d.ts",
            "import": "./chains/paseo-asset-hub/generated/dist/index.js"
        },
        "./paseo-bulletin": {
            "types": "./chains/paseo-bulletin/generated/dist/index.d.ts",
            "import": "./chains/paseo-bulletin/generated/dist/index.js"
        },
        "./paseo-individuality": {
            "types": "./chains/paseo-individuality/generated/dist/index.d.ts",
            "import": "./chains/paseo-individuality/generated/dist/index.js"
        },
        "./polkadot-asset-hub": {
            "types": "./chains/polkadot-asset-hub/generated/dist/index.d.ts",
            "import": "./chains/polkadot-asset-hub/generated/dist/index.js"
        },
        "./summit-asset-hub": {
            "types": "./chains/summit-asset-hub/generated/dist/index.d.ts",
            "import": "./chains/summit-asset-hub/generated/dist/index.js"
        },
        "./summit-bulletin": {
            "types": "./chains/summit-bulletin/generated/dist/index.d.ts",
            "import": "./chains/summit-bulletin/generated/dist/index.js"
        },
        "./summit-individuality": {
            "types": "./chains/summit-individuality/generated/dist/index.d.ts",
            "import": "./chains/summit-individuality/generated/dist/index.js"
        }
    },
    "scripts": {
        "generate": "./scripts/generate.sh",
        "build": "./scripts/build.sh",
        "clean": "rm -rf chains/*/generated/dist chains/*/generated/src chains/*/generated/generated.json"
    },
    "dependencies": {
        "polkadot-api": "catalog:"
    },
    "devDependencies": {
        "typescript": "^5.8.3"
    },
    "files": [
        "chains/*/generated/dist/**/*.js",
        "chains/*/generated/dist/**/*.d.ts",
        "chains/*/.papi/**/*"
    ]
}
