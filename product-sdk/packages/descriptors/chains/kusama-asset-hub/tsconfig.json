  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "declaration": true,
    "declarationMap": true,
    "outDir": "./generated",
    "rootDir": "./generated",
    "strict": true,
    "skipLibCheck": true
  },
  "include": ["generated/**/*.ts"]
}
