{
  "name": "@parity/product-sdk-chain-client",
  "version": "0.0.1",
  "description": "Multi-chain Polkadot API client with typed access to Asset Hub, Bulletin, and other chains",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsup",
    "test": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@parity/product-sdk-logger": "workspace:*",
    "@parity/product-sdk-host": "workspace:*",
    "polkadot-api": "^1.9.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "license": "Apache-2.0"
}
