{
    "name": "@parity/product-sdk-cloud-storage",
    "version": "0.6.6",
    "description": "TypeScript SDK for uploading and retrieving data from the Cloud (currently through the Polkadot Bulletin Chain)",
    "type": "module",
    "sideEffects": false,
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts"
        }
    },
    "files": ["dist", "src"],
    "scripts": {
        "build": "tsup",
        "test": "vitest",
        "clean": "rm -rf dist"
    },
    "dependencies": {
        "@parity/bulletin-sdk": "^0.3.0",
        "@parity/product-sdk-chain-client": "workspace:*",
        "@parity/product-sdk-descriptors": "workspace:*",
        "@parity/product-sdk-host": "workspace:*",
        "@parity/product-sdk-logger": "workspace:*",
        "@parity/product-sdk-tx": "workspace:*",
        "multiformats": "^13.3.0",
        "polkadot-api": "catalog:"
    },
    "devDependencies": {
        "typescript": "^5.7.0",
        "vitest": "^3.0.0"
    },
    "license": "Apache-2.0"
}
