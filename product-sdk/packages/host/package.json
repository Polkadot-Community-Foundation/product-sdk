{
    "name": "@parity/product-sdk-host",
    "version": "0.10.1",
    "description": "Host container detection and storage access for Polkadot Desktop and Mobile environments",
    "type": "module",
    "sideEffects": false,
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
