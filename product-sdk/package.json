{
  "name": "@parity/product-sdk-monorepo",
  "version": "0.1.0-beta.1",
  "private": true,
  "description": "Monorepo for @parity/product-sdk packages",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "test:e2e": "pnpm --filter \"@parity/product-sdk-*-demo\" test:e2e",
    "lint": "pnpm -r lint",
    "clean": "pnpm -r clean",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint:biome": "biome lint .",
    "check": "biome check ."
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  }
}
